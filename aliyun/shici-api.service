[Unit]
Description=Shici WeChat Login and Cloud Library API
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=shici
Group=shici
WorkingDirectory=/opt/shici/api
EnvironmentFile=/opt/shici/api/.env
ExecStart=/usr/bin/node /opt/shici/api/server.js
Restart=always
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/shici

[Install]
WantedBy=multi-user.target
